# Server configuration
PORT=5000
JWT_SECRET=your_jwt_secret_key_here

# Administrator Credentials (used for logging into the dashboard)
ADMIN_EMAIL=admin@bonappetite.com
ADMIN_PASSWORD=your_secure_admin_password_here

# Database Configuration (Supabase PostgreSQL integration)
# Leave blank to fall back automatically to the in-memory mock database
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Email SMTP Settings (Nodemailer invitations)
# Leave blank to log email contents to standard output instead
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password_here
EMAIL_FROM="Bon Appetite Cafe" <your_email@gmail.com>

# WhatsApp Twilio Settings (Twilio Sandbox or verified number)
# Leave blank to log WhatsApp messages to standard output instead
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_WHATSAPP_NUMBER=
